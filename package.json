{
  "name": "cycles-docs",
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "finalhandler": "^2.1.1",
    "png-to-ico": "^3.0.1",
    "puppeteer": "^23.11.1",
    "serve-static": "^2.2.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "convert-spec": "node scripts/convert-spec.js",
    "build": "npm run convert-spec && bash scripts/generate-llms-full.sh && vitepress build",
    "build:with-pdfs": "npm run build && node scripts/generate-pdfs.js",
    "pdfs": "node scripts/generate-pdfs.js",
    "dev": "npm run convert-spec && vitepress dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "feed": "^5.2.0",
    "medium-zoom": "^1.1.0",
    "shiki": "^4.0.2",
    "vitepress-openapi": "^0.1.20",
    "yaml": "^2.8.2"
  }
}
